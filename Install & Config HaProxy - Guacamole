===============================
sudo mkdir -p /etc/haproxy/certs
sudo openssl req -x509 -nodes -days 365 -newkey rsa:2048 -keyout /etc/haproxy/certs/haproxy.pem -out /etc/haproxy/certs/haproxy.pem -subj "/CN=tondomaine.fr"
sudo chmod 600 /etc/haproxy/certs/haproxy.pem


