==================================================
PARTIE I : INSTALLATION & CONFIGURATION DE HAPROXY
==================================================


Etape 1 : Installation depuis les dépôts officiels
==================================================
sudo apt update && sudo apt upgrade -y
sudo apt install haproxy -y


Etape 2 : Activer le service
============================
sudo systemctl enable haproxy


Etape 3 : Préparation du Certificat SSL
=======================================
# Sauvegarde du fichier par défaut
sudo cp /etc/haproxy/haproxy.cfg /etc/haproxy/haproxy.cfg.bak

# Editer le fichier de configuration
sudo nano /etc/haproxy/haproxy.cfg
# Adaptez selon votre environnement (Mot de passe, IP)

Contenu :
---------

#---------------------------------------------------------------------
# Global settings - SÉCURITÉ RENFORCÉE
#---------------------------------------------------------------------
global
    log /dev/log local0
    log /dev/log local1 notice
    chroot /var/lib/haproxy
    stats socket /run/haproxy/admin.sock mode 660 level admin
    stats timeout 30s
    user haproxy
    group haproxy
    daemon

    ssl-default-bind-ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384
    ssl-default-bind-ciphersuites TLS_AES_128_GCM_SHA256:TLS_AES_256_GCM_SHA384:TLS_CHACHA20_POLY1305_SHA256
    ssl-default-bind-options ssl-min-ver TLSv1.2 no-tls-tickets
    tune.ssl.default-dh-param 2048
    maxconn 10000

#---------------------------------------------------------------------
# Liste des utilisateurs pour les statistiques
#---------------------------------------------------------------------
userlist stats_users
    user admin insecure-password MOT_DE_PASSE

#---------------------------------------------------------------------
# Defaults - SÉCURITÉ RENFORCÉE
#---------------------------------------------------------------------
defaults
    log     global
    mode    http
    option  httplog
    option  dontlognull
    option  redispatch

    timeout connect 5s
    timeout client  30s
    timeout server  30s
    timeout http-request 10s
    timeout http-keep-alive 5s

    option http-server-close
    option httpclose
    maxconn 2000
    retries 3

    errorfile 400 /etc/haproxy/errors/400.http
    errorfile 403 /etc/haproxy/errors/403.http
    errorfile 408 /etc/haproxy/errors/408.http
    errorfile 500 /etc/haproxy/errors/500.http
    errorfile 502 /etc/haproxy/errors/502.http
    errorfile 503 /etc/haproxy/errors/503.http
    errorfile 504 /etc/haproxy/errors/504.http

#---------------------------------------------------------------------
# Frontend HTTP/HTTPS - LA PORTE D'ENTRÉE EXPOSÉE
#---------------------------------------------------------------------
frontend http_front
    bind *:80
    # ATTENTION: S'assurer que le fichier.pem existe bien
    bind *:443 ssl crt /etc/haproxy/certs/haproxy.pem

    # 1. Rate limiting (DDoS Protection)
    stick-table type ip size 100k expire 30s store http_req_rate(10s)
    http-request track-sc0 src
    http-request deny deny_status 429 if { sc_http_req_rate(0) gt 10 }

    # 2. Blocage bots malveillants
    acl bad_bot hdr_sub(User-Agent) -i nikto sqlmap nmap masscan
    http-request deny deny_status 403 if bad_bot

    # 3. Anti-scan chemins sensibles
    acl scan_attempt path_beg -i /.env /admin /phpMyAdmin /.git /wp-admin
    http-request deny deny_status 404 if scan_attempt

    # 4. Redirection HTTPS forcée
    redirect scheme https code 301 if !{ ssl_fc }

    # 5. Headers sécurité (WAF layer)
    http-response set-header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    http-response set-header X-Frame-Options "SAMEORIGIN"
    http-response set-header X-Content-Type-Options "nosniff"
    http-response set-header X-XSS-Protection "1; mode=block"
    http-response set-header Referrer-Policy "strict-origin-when-cross-origin"
    http-response set-header Permissions-Policy "geolocation=(), microphone=(), camera=()"
    http-response del-header Server

    # 6. Routing
    acl is_stats path_beg /haproxy
    use_backend stats_back if is_stats

    # Par défaut, tout le trafic sain va vers Guacamole
    default_backend guacamole_back

#---------------------------------------------------------------------
# Backend Statistiques HAProxy
#---------------------------------------------------------------------
backend stats_back
    stats enable
    stats uri /haproxy?stats
    stats refresh 30s
    stats admin if TRUE
    http-request auth unless { http_auth(stats_users) }

#---------------------------------------------------------------------
# Backend GUACAMOLE - Bastion
#---------------------------------------------------------------------
backend guacamole_back
    balance roundrobin

    # Rate limiting spécifique aux connexions TCP vers Guacamole
    stick-table type ip size 100k expire 30s store conn_cur,conn_rate(10s)
    tcp-request content track-sc1 src
    tcp-request content reject if { sc_conn_rate(1) gt 50 }

    # PARAMÈTRE CRUCIAL POUR GUACAMOLE : Ne pas couper les WebSockets
    timeout tunnel 3600s

    # Indispensable : Transférer la vraie IP pour Crowdsec et Guacamole
    option forwardfor
    http-request set-header X-Real-IP %[src]
    http-request set-header X-Forwarded-Proto https if { ssl_fc }

    # Redirige automatiquement vers /guacamole/ si l'utilisateur tape juste votre domaine
    http-request set-path /guacamole%[path] if { path -m str / }

    # Healthcheck : vérifie que Tomcat/Guacamole répond bien
    option httpchk
    http-check send meth GET uri /guacamole/ ver HTTP/1.1 hdr Host localhost
    http-check expect status 200

    # L'IP DU GUACAMOLE EST ICI (Vérifier si c'est le port 8080 ou 80 selon l'install)
    server guac1 192.168.100.2:8081 check inter 2000 rise 2 fall 3 maxconn 500
    # Dans ce cas de figure, le port de guacamole est paramétré sur 8081 afin d'éviter des conflits avec d'autres services qui portent ce port comme "Crowdsec ou Keycloak"



